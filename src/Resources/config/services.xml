<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Carve\Shopware\Service\CarveRenderer"/>

        <service id="Carve\Shopware\Twig\CarveExtension">
            <argument type="service" id="Carve\Shopware\Service\CarveRenderer"/>
            <tag name="twig.extension"/>
        </service>

        <service id="Carve\Shopware\Core\Content\Cms\CarveCmsElementResolver">
            <argument type="service" id="Carve\Shopware\Service\CarveRenderer"/>
            <tag name="shopware.cms.data_resolver"/>
        </service>

        <service id="Carve\Shopware\Service\CarveContextRenderer">
            <argument type="service" id="product.repository"/>
        </service>

        <service id="Carve\Shopware\Twig\CarveContextExtension">
            <argument type="service" id="Carve\Shopware\Service\CarveContextRenderer"/>
            <tag name="twig.extension"/>
        </service>

        <service id="Carve\Shopware\Command\CarveRenderCommand">
            <tag name="console.command"/>
        </service>
    </services>
</container>
